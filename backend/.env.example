# ============================================================
# EQUESTO BACKEND - Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env — ele está no .gitignore
# ============================================================

# ------------------------------------------------------------
# OBRIGATÓRIAS — o app não sobe sem estas
# ------------------------------------------------------------

# Banco de dados (Railway preenche automaticamente ao provisionar o Postgres)
DATABASE_URL=postgresql://usuario:senha@host:5432/equesto

# JWT — gere uma chave forte em: https://randomkeygen.com (use "CodeIgniter Encryption Keys")
JWT_SECRET=SUBSTITUA_POR_UMA_CHAVE_FORTE_E_ALEATORIA_DE_64_CHARS

# ------------------------------------------------------------
# UPLOAD DE IMAGENS (Cloudinary)
# Crie conta gratuita em: https://cloudinary.com
# Copie a CLOUDINARY_URL do Dashboard → API Keys
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# ------------------------------------------------------------
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ------------------------------------------------------------
# CORS — URL do painel admin em produção
# Sem isso o admin não consegue fazer requisições à API
# ------------------------------------------------------------
ADMIN_URL=https://seu-admin.railway.app

# ------------------------------------------------------------
# OPCIONAL — Railway define automaticamente
# ------------------------------------------------------------
PORT=3000
NODE_ENV=production
